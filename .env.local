# .env.local — Run Orchestrator locally (no Docker)
# Usage: $env:ENV_FILE=".env.local"; uvicorn app.main:app --port 8000 --reload

ENV_FILE=.env.local

LLM_PROVIDER=groq
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# --- Groq (fill in your key) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# --- xAI / Grok (optional) ---
XAI_API_KEY=

REDIS_URL=redis://localhost:6379

CONTEXT_AGENT_URL=http://localhost:8001
SQL_AGENT_URL=http://localhost:8002
VIZ_AGENT_URL=http://localhost:8003
ML_AGENT_URL=http://localhost:8004
NLP_AGENT_URL=http://localhost:8005
REPORT_AGENT_URL=http://localhost:8006

USE_DOCKER=false
USE_EC2=false
PORT=8000
