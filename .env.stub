# .env.stub — points Orchestrator at localhost stub agents (no Docker needed)
#
# Start stubs first:   python stubs/run_stubs.py
# Start Orchestrator:  $env:ENV_FILE=".env.stub"; uvicorn app.main:app --port 8000 --reload
# Run demo:            python stubs/demo_client.py
#
# ENV_FILE tells config.py to load ONLY this file (avoids Docker URLs from .env.free/.env.paid)
ENV_FILE=.env.stub

LLM_PROVIDER=stub
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:0.6b

REDIS_URL=redis://localhost:6379

CONTEXT_AGENT_URL=http://localhost:8001
SQL_AGENT_URL=http://localhost:8002
VIZ_AGENT_URL=http://localhost:8003
ML_AGENT_URL=http://localhost:8004
NLP_AGENT_URL=http://localhost:8005
REPORT_AGENT_URL=http://localhost:8006

USE_DOCKER=false
USE_EC2=false
PORT=8000
